      "name": "Dropbox–Drive dedupe",
      "enabled": true,
      "createdAtMs": 1774015598793,
      "updatedAtMs": 1774227559185,
      "schedule": {
        "kind": "every",
        "everyMs": 604800000,
        "anchorMs": 1774016746664
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Cross-reference all Dropbox files with all Google Drive files using Composio, but use only simple, safe matching that does NOT depend on Composio remote workbench. Treat Google Drive as canonical. For each Dropbox file that is a very likely duplicate of a Drive file based on filename (same or very similar) AND file size (identical or extremely close), treat it as a duplicate. Do NOT download or compare full content; skip anything ambiguous. Move only those high-confidence Dropbox duplicates into /cleanup, preserving some of their original structure (e.g. /cleanup/Personal/..., /cleanup/Career/...). Do not delete any files. After each run, summarize how many files were scanned and how many were moved, and include 5 example pairs of (Dropbox moved file, matching Drive file)."
      },
      "delivery": {
        "mode": "silent"
      },
